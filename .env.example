# LA Rent Finder - Environment Variables
# Copy this file to .env.local and fill in your values

# ==============================================
# Supabase Configuration
# ==============================================
# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard -> Settings -> API

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous/public key (safe to expose in client-side code)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (KEEP SECRET! Server-side only)
# This key bypasses Row-Level Security - use with caution
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==============================================
# Mapbox Configuration
# ==============================================
# Get your token from: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token-here

# ==============================================
# API Configuration
# ==============================================
# Base URL for API calls (use http://localhost:3000 for development)
NEXT_PUBLIC_API_URL=http://localhost:3000

# ==============================================
# AI/LLM Configuration (Required for agents)
# ==============================================
# Anthropic API Key (required for Claude-powered agents)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API Key (optional, for GPT-powered features)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# ==============================================
# MCP Server Configuration - Linear
# ==============================================
# Linear API integration for project management
# Get your API key from: https://linear.app/settings/api
LINEAR_API_KEY=your-linear-api-key-here

# ==============================================
# MCP Server Configuration - GitHub
# ==============================================
# GitHub integration for repository management
# Create a Personal Access Token: https://github.com/settings/tokens
# Required scopes: repo, workflow
GITHUB_PERSONAL_ACCESS_TOKEN=your-github-token-here

# Owner of the GitHub repository
GITHUB_OWNER=your-github-username

# Name of the GitHub repository
GITHUB_REPO=la-rent-finder

# ==============================================
# MCP Server Configuration - Slack
# ==============================================
# Slack integration for team notifications
# Create Slack app: https://api.slack.com/apps
# Required scopes: chat:write, channels:read
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_TEAM_ID=your-team-id

# ==============================================
# MCP Server Configuration - Firecrawl
# ==============================================
# Firecrawl API for web scraping rental listings
# Get API key from: https://firecrawl.dev/dashboard
FIRECRAWL_API_KEY=your-firecrawl-api-key-here

# ==============================================
# MCP Server Configuration - Browserbase
# ==============================================
# Browserbase for browser automation and web scraping
# Get API key from: https://browserbase.com/dashboard
BROWSERBASE_API_KEY=your-browserbase-api-key-here
BROWSERBASE_PROJECT_ID=your-browserbase-project-id

# ==============================================
# MCP Server Configuration - Supabase MCP
# ==============================================
# These are the same as the Supabase config above
# Just documented here for MCP server clarity
# SUPABASE_URL=${NEXT_PUBLIC_SUPABASE_URL}
# SUPABASE_SERVICE_KEY=${SUPABASE_SERVICE_ROLE_KEY}

# ==============================================
# Real Estate API Keys
# ==============================================
# RapidAPI key for Realty in US API (500 free calls/mo on Basic plan)
# Get yours at: https://rapidapi.com/apidojo/api/realty-in-us
RAPIDAPI_KEY=your-rapidapi-key-here

# RentCast API key (50 free calls/mo)
# Get yours at: https://developers.rentcast.io/
RENTCAST_API_KEY=your-rentcast-api-key-here

# ==============================================
# Optional: Email Configuration
# ==============================================
# For sending appointment reminders and notifications
# SENDGRID_API_KEY=your-sendgrid-key-here
# FROM_EMAIL=noreply@yourapp.com
